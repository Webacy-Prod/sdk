{
  "name": "webacy-sdk-monorepo",
  "version": "1.5.0",
  "private": true,
  "description": "Webacy SDK Monorepo - TypeScript SDKs for the Webacy Risk Score API",
  "author": "Webacy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Webacy-Prod/sdk.git"
  },
  "bugs": {
    "url": "https://github.com/Webacy-Prod/sdk/issues"
  },
  "homepage": "https://github.com/Webacy-Prod/sdk#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:integration:api": "node test-real-api.js",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"packages/*/src/**/*.ts\"",
    "format:check": "prettier --check \"packages/*/src/**/*.ts\"",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#**/node_modules\" \"#docs-site/.docusaurus\" \"#docs-site/build\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "typecheck": "turbo run typecheck",
    "docs": "cd docs-site && pnpm start",
    "docs:build": "cd docs-site && pnpm build",
    "docs:serve": "cd docs-site && pnpm serve",
    "prepublishOnly": "pnpm build && pnpm test",
    "publish:dry-run": "pnpm build && pnpm -r publish --dry-run --access public",
    "publish:all": "pnpm build && pnpm -r publish --access public",
    "version:patch": "pnpm -r exec npm version patch --no-git-tag-version",
    "version:minor": "pnpm -r exec npm version minor --no-git-tag-version",
    "version:major": "pnpm -r exec npm version major --no-git-tag-version",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "markdownlint-cli2": "^0.14.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.2.0",
    "tslib": "^2.6.0",
    "turbo": "^2.0.0",
    "typedoc": "^0.28.0",
    "typescript": "^5.7.0",
    "vitest": "^1.3.0"
  },
  "lint-staged": {
    "packages/*/src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.md": [
      "markdownlint-cli2 --fix"
    ]
  }
}
