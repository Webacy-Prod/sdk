{
  "name": "@webacy/sdk-threat",
  "version": "1.0.0",
  "description": "Webacy SDK for threat and risk analysis - address risk, sanctions, contracts, URL safety",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs && npm run build:types && npm run postbuild",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:types": "tsc -p tsconfig.types.json",
    "postbuild": "echo '{\"type\":\"module\"}' > dist/esm/package.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@webacy/sdk-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "webacy",
    "sdk",
    "threat",
    "risk",
    "security",
    "sanctions",
    "address-risk",
    "contract-analysis",
    "blockchain",
    "crypto"
  ],
  "author": "Webacy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Webacy-Prod/sdk.git",
    "directory": "packages/threat"
  },
  "bugs": {
    "url": "https://github.com/Webacy-Prod/sdk/issues"
  },
  "homepage": "https://github.com/Webacy-Prod/sdk/tree/main/packages/threat#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
